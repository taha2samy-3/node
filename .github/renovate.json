{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:best-practices"
    ],
    "dependencyDashboard": true,
    "pinDigests": true,
    "packageRules": [
        {
            "matchManagers": [
                "dockerfile",
                "docker-compose"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "automerge": true
        },
        {
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "github-actions-dependencies",
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "automerge": true
        },
        {
            "matchManagers": [
                "pipenv"
            ],
            "groupName": "mkdocs-dependencies",
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "automerge": true
        }
    ],
    "postUpdateOptions": [
        "pipenvKeepVar"
    ]
}